%% CuePoint — Backend Architecture (C4-style container view)
%% Source of truth for the rendered diagram in backend-architecture.md
%% Edit here, then re-render.

graph TB
    %% ──────────────── External Actors ────────────────
    subgraph Users["End Users (Canvas iframe)"]
        Instructor["Instructor<br/>browser"]
        Student["Student<br/>browser"]
    end

    %% ──────────────── External Systems ────────────────
    subgraph External["External Systems"]
        Canvas["Canvas LMS<br/>(LTI 1.3 Platform)<br/>OIDC · AGS · NRPS · Deep Linking"]
        Claude["Anthropic Claude API<br/>(@anthropic-ai/sdk)"]
    end

    %% ──────────────── CuePoint App ────────────────
    subgraph CuePoint["CuePoint — Next.js app (Vercel serverless)"]

        subgraph Edge["Edge / Middleware layer — src/middleware.ts"]
            MW["Next.js middleware<br/>• Rate limiting (general + AI tier)<br/>• Session cookie validation<br/>• Admin bearer-token guard<br/>• Request logging / timing headers"]
        end

        subgraph Web["Web layer — src/app (App Router)"]
            DashUI["/dashboard<br/>Instructor UI<br/>(assessments, question bank,<br/>groups, analytics, mastery)"]
            AssessUI["/assess<br/>Student assessment UI<br/>(14 question types, STEM editor)"]
        end

        subgraph API["API layer — src/app/api (Route Handlers)"]
            direction TB
            LTIApi["/api/lti/*<br/>login · launch · callback<br/>deep-link · jwks · roster<br/>registration · warmup"]
            AuthApi["/api/auth/*<br/>NextAuth Canvas OAuth"]
            DemoApi["/api/demo/*<br/>No-Canvas demo login"]
            AssessApi["/api/assessments<br/>/api/assessment-groups<br/>/api/questions"]
            SubApi["/api/submissions<br/>start · answer · submit"]
            GradeApi["/api/grades<br/>Canvas grade passback"]
            AnalyticsApi["/api/analytics<br/>/api/mastery<br/>/api/objectives<br/>/api/students"]
            AiApi["/api/ai/*<br/>generate · generate-assessment<br/>grade · insights · ask<br/>student-insights<br/>speech-to-latex · extract-text"]
            QtiApi["/api/qti/*<br/>import · export"]
            AdminApi["/api/admin/*<br/>institutions · platforms<br/>nonce-cleanup"]
        end

        subgraph Lib["Core services — src/lib"]
            direction TB
            LtiLib["lti.ts · lti-keys.ts<br/>OIDC, JWT sign/verify (jose),<br/>AGS grade passback,<br/>NRPS roster sync,<br/>Deep Linking"]
            AuthLib["auth.ts<br/>session + role checks<br/>(requireRole)"]
            GradingLib["grading.ts<br/>Auto-grader<br/>(MC, numeric, matching,<br/>ordering, FIB, partial credit)"]
            AiLib["ai.ts<br/>Claude prompts: generate,<br/>grade, insights, Q&A,<br/>speech→LaTeX"]
            MasteryLib["mastery.ts<br/>psychometrics.ts<br/>Objective tracking,<br/>Bloom's, IRT/difficulty"]
            TenantLib["tenant.ts<br/>Per-institution schema<br/>resolution"]
            RateLib["rate-limit.ts<br/>(rate-limiter-flexible)"]
            ValidLib["validation.ts<br/>Zod request schemas"]
            ImportLib["question-import.ts<br/>qti/<br/>CSV/Excel/QTI parsing (xlsx)"]
            DbLib["db.ts<br/>pg Pool + query/transaction,<br/>tenantQuery / tenantTransaction<br/>(SET search_path)"]
        end

        subgraph Data["Data layer — PostgreSQL"]
            PublicSchema[("public schema<br/>institutions, lti_platforms,<br/>lti_oidc_states, lti_nonces,<br/>lti_registrations")]
            TenantSchema[("tenant_&lt;institution&gt; schemas<br/>users · courses · enrollments<br/>question_banks · questions<br/>assessments · assessment_groups<br/>submissions · question_responses<br/>response_events · usage_events<br/>learning_objectives · student_mastery<br/>lti_launch_contexts · lti_access_tokens")]
        end
    end

    %% ──────────────── Edges: User traffic ────────────────
    Instructor -->|HTTPS embed<br/>in Canvas iframe| MW
    Student -->|HTTPS embed<br/>in Canvas iframe| MW
    MW --> DashUI
    MW --> AssessUI
    MW --> API

    DashUI -.fetch.-> API
    AssessUI -.fetch.-> API

    %% ──────────────── Edges: LTI handshake with Canvas ────────────────
    Canvas ==>|1. OIDC login_hint| LTIApi
    LTIApi ==>|2. auth redirect| Canvas
    Canvas ==>|3. id_token launch| LTIApi
    LTIApi -.JWKS fetch.-> Canvas
    LTIApi -.NRPS roster.-> Canvas
    GradeApi ==>|AGS line items<br/>+ score passback| Canvas

    %% ──────────────── Edges: API → lib ────────────────
    LTIApi --> LtiLib
    AuthApi --> AuthLib
    DemoApi --> AuthLib
    AssessApi --> ValidLib
    AssessApi --> DbLib
    SubApi --> GradingLib
    SubApi --> DbLib
    GradeApi --> LtiLib
    AnalyticsApi --> MasteryLib
    AnalyticsApi --> DbLib
    AiApi --> AiLib
    AiApi --> ValidLib
    QtiApi --> ImportLib
    AdminApi --> DbLib
    LtiLib --> DbLib
    GradingLib --> DbLib
    MasteryLib --> DbLib
    ImportLib --> DbLib
    AuthLib --> DbLib

    %% ──────────────── Edges: tenant resolution ────────────────
    DbLib --> TenantLib
    TenantLib -.resolves schema.-> TenantSchema
    DbLib --> PublicSchema
    DbLib --> TenantSchema

    %% ──────────────── Edges: AI ────────────────
    AiLib ==>|HTTPS<br/>model calls| Claude

    %% ──────────────── Styling ────────────────
    classDef external fill:#fde68a,stroke:#b45309,color:#1f2937;
    classDef edge fill:#e0e7ff,stroke:#3730a3,color:#1f2937;
    classDef web fill:#dcfce7,stroke:#166534,color:#1f2937;
    classDef api fill:#dbeafe,stroke:#1d4ed8,color:#1f2937;
    classDef lib fill:#ede9fe,stroke:#6d28d9,color:#1f2937;
    classDef data fill:#fee2e2,stroke:#b91c1c,color:#1f2937;
    classDef user fill:#f3f4f6,stroke:#374151,color:#1f2937;

    class Instructor,Student user;
    class Canvas,Claude external;
    class MW edge;
    class DashUI,AssessUI web;
    class LTIApi,AuthApi,DemoApi,AssessApi,SubApi,GradeApi,AnalyticsApi,AiApi,QtiApi,AdminApi api;
    class LtiLib,AuthLib,GradingLib,AiLib,MasteryLib,TenantLib,RateLib,ValidLib,ImportLib,DbLib lib;
    class PublicSchema,TenantSchema data;
